{
  "name": "pg-toolbelt",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "cpu-features": "file:./.stubs/cpu-features"
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "format-and-lint": "biome check . --error-on-warnings",
    "knip": "bun run --filter '*' knip",
    "test": "bun run --filter '*' test",
    "test:pg-delta": "cd packages/pg-delta && bun test --concurrent --timeout 15000 --preload ./tests/global-setup.ts --max-concurrency=4",
    "test:pg-topo": "bun run --filter '@supabase/pg-topo' test",
    "version": "changeset version"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "^1.3.9",
    "bun": "^1.3.9"
  }
}

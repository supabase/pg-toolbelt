{
  "name": "@supabase/bun-istanbul-coverage",
  "version": "1.0.0-alpha.0",
  "description": "Drop-in Bun preload plugin that replaces JSC coverage with Istanbul source instrumentation",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preload": {
      "bun": "./src/preload.ts",
      "import": "./dist/preload.js",
      "types": "./dist/preload.d.ts",
      "default": "./dist/preload.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "author": "Supabase",
  "license": "MIT",
  "homepage": "https://github.com/supabase/pg-toolbelt",
  "repository": {
    "type": "git",
    "url": "https://github.com/supabase/pg-toolbelt.git",
    "directory": "packages/bun-istanbul-coverage"
  },
  "bugs": "https://github.com/supabase/pg-toolbelt/issues",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "check-types": "tsc --noEmit",
    "format-and-lint": "biome check . --error-on-warnings"
  },
  "dependencies": {
    "istanbul-lib-instrument": "^6.0.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/istanbul-lib-instrument": "^1.7.8",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "bun": ">=1.0.0"
  }
}
